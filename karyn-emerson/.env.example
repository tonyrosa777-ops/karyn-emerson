# Karyn Emerson Real Estate — Environment Variables
# Never commit real keys. Copy to .env.local and fill per environment.

# Public site URL (used for Stripe success/cancel redirects + metadataBase)
NEXT_PUBLIC_SITE_URL=https://karynemerson.com

# Booking (Calendly)
CALENDLY_API_KEY=
NEXT_PUBLIC_CALENDLY_EVENT_TYPE_URI=

# Shop (Premium tier — demo renders without these via seeded fallback)
PRINTFUL_API_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
RESEND_API_KEY=
