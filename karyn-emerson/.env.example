# Karyn Emerson Real Estate — Environment Variables
# Never commit real keys. Copy to .env.local and fill per environment.

# Public site URL (used for Stripe success/cancel redirects + metadataBase)
NEXT_PUBLIC_SITE_URL=https://karynemerson.com

# Booking (Calendly inline embed — public scheduling link, no API key)
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/karyn-jillandco/30min

# Shop (Premium tier — hidden by default; flip flag to true on Premium upgrade)
NEXT_PUBLIC_SHOP_ENABLED=false
PRINTFUL_API_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
RESEND_API_KEY=
